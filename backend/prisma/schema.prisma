// ============================================
// TRANSFORMATOR MONITORING TIZIMI
// Ma'lumotlar bazasi sxemasi (Prisma ORM)
// Davlat miqyosidagi loyiha
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// FOYDALANUVCHILAR VA AUTENTIFIKATSIYA
// ============================================

enum UserRole {
  ADMIN
  EMPLOYEE
  INSPECTOR
}

// Hudud biriktirish turi
enum AssignmentType {
  REGION      // Butun viloyat
  DISTRICTS   // Aniq tumanlar
  POLYGON     // Xususiy xarita chegarasi
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  fullName      String    @map("full_name")
  phone         String?
  role          UserRole  @default(EMPLOYEE)
  
  // Hudud biriktirish turi
  assignmentType AssignmentType? @map("assignment_type")
  
  // Viloyat bo'yicha biriktirish
  regionId      String?   @map("region_id")
  region        Region?   @relation(fields: [regionId], references: [id])
  
  // Tumanlar bo'yicha biriktirish (UUID array)
  districtIds   String[]  @default([]) @map("district_ids")
  
  // Xususiy poligon (GeoJSON coords array)
  customPolygon Json?     @map("custom_polygon")
  
  // Tekshiruvchi uchun muddatli kirish
  expiresAt     DateTime? @map("expires_at")
  
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  createdTransformers   Transformer[]   @relation("CreatedBy")
  performedMaintenance  Maintenance[]   @relation("PerformedBy")
  conductedInspections  Inspection[]    @relation("InspectorRel")
  reportedIncidents     Incident[]      @relation("ReportedBy")
  resolvedAlerts        Alert[]         @relation("ResolvedBy")
  assignedWorkOrders    WorkOrder[]     @relation("AssignedTo")
  auditLogs             AuditLog[]
  createdWorkPermits    WorkPermit[]    @relation("WorkPermitCreatedBy")
  refreshTokens         RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

// ============================================
// HUDUDLAR
// ============================================

model Region {
  id          String   @id @default(uuid())
  name        String
  nameRu      String?  @map("name_ru")
  nameEn      String?  @map("name_en")
  code        String   @unique
  population  Int      @default(0)
  areaKm2     Float    @default(0) @map("area_km2")
  description String?
  polygonCoords Json?  @map("polygon_coords")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  districts     District[]
  substations   Substation[]
  transformers  Transformer[]
  users         User[]

  @@map("regions")
}

model District {
  id          String   @id @default(uuid())
  name        String
  nameRu      String?  @map("name_ru")
  nameEn      String?  @map("name_en")
  code        String   @unique
  regionId    String   @map("region_id")
  region      Region   @relation(fields: [regionId], references: [id])
  population  Int      @default(0)
  areaKm2     Float    @default(0) @map("area_km2")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  substations   Substation[]
  transformers  Transformer[]

  @@map("districts")
}

// ============================================
// PODSTANSIYALAR
// ============================================

model Substation {
  id                String    @id @default(uuid())
  name              String
  code              String    @unique
  regionId          String    @map("region_id")
  region            Region    @relation(fields: [regionId], references: [id])
  districtId        String?   @map("district_id")
  district          District? @relation(fields: [districtId], references: [id])
  latitude          Float?
  longitude         Float?
  address           String?
  photoUrl          String?   @map("photo_url")
  commissionedDate  DateTime? @map("commissioned_date")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  transformers      Transformer[]

  @@map("substations")
}

// ============================================
// TRANSFORMATORLAR
// ============================================

enum TransformerStatus {
  OPERATIONAL
  WARNING
  CRITICAL
  OFFLINE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Transformer {
  id                  String             @id @default(uuid())
  inventoryNumber     String             @unique @map("inventory_number")
  model               String?
  manufacturer        String?
  networkName         String?            @map("network_name")
  substationId        String?            @map("substation_id")
  substation          Substation?        @relation(fields: [substationId], references: [id])
  regionId            String             @map("region_id")
  region              Region             @relation(fields: [regionId], references: [id])
  districtId          String?            @map("district_id")
  district            District?          @relation(fields: [districtId], references: [id])
  latitude            Float
  longitude           Float
  address             String?
  capacityKva         Int                @map("capacity_kva")
  manufactureYear     Int?               @map("manufacture_year")
  installationDate    DateTime?          @map("installation_date")
  connectedHouseholds Int                @default(0) @map("connected_households")
  estimatedPopulation Int                @default(0) @map("estimated_population")
  areaType            String?            @map("area_type")
  healthScore         Float              @default(100) @map("health_score")
  riskLevel           RiskLevel          @default(LOW) @map("risk_level")
  status              TransformerStatus  @default(OPERATIONAL)
  isOnline            Boolean            @default(false) @map("is_online")
  loadPercent         Float              @default(0) @map("load_percent")
  photoUrl            String?            @map("photo_url")
  photos              Json?
  notes               String?
  createdById         String?            @map("created_by_id")
  createdBy           User?              @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  
  alerts              Alert[]
  maintenance         Maintenance[]
  inspections         Inspection[]
  incidents           Incident[]
  workOrders          WorkOrder[]
  workPermits         WorkPermit[]

  @@index([regionId])
  @@index([districtId])
  @@index([status])
  @@index([latitude, longitude])
  @@map("transformers")
}

// ============================================
// OGOHLANTIRISHLAR
// ============================================

enum AlertPriority { ACTIVE CRITICAL EMERGENCY }
enum AlertStatus { OPEN ACKNOWLEDGED RESOLVED }

model Alert {
  id              String        @id @default(uuid())
  transformerId   String        @map("transformer_id")
  transformer     Transformer   @relation(fields: [transformerId], references: [id])
  priority        AlertPriority
  title           String
  description     String?
  status          AlertStatus   @default(OPEN)
  resolvedAt      DateTime?     @map("resolved_at")
  resolvedById    String?       @map("resolved_by_id")
  resolvedBy      User?         @relation("ResolvedBy", fields: [resolvedById], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([transformerId])
  @@index([status])
  @@index([priority])
  @@map("alerts")
}

// ============================================
// TEXNIK XIZMAT
// ============================================

enum MaintenanceStatus { SCHEDULED IN_PROGRESS COMPLETED CANCELLED }

model Maintenance {
  id              String            @id @default(uuid())
  transformerId   String            @map("transformer_id")
  transformer     Transformer       @relation(fields: [transformerId], references: [id])
  workType        String            @map("work_type")
  description     String?
  scheduledDate   DateTime?         @map("scheduled_date")
  completedDate   DateTime?         @map("completed_date")
  performedById   String?           @map("performed_by_id")
  performedBy     User?             @relation("PerformedBy", fields: [performedById], references: [id])
  status          MaintenanceStatus @default(SCHEDULED)
  cost            Float?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([transformerId])
  @@map("maintenance_records")
}

// ============================================
// TEKSHIRUVLAR
// ============================================

enum InspectionResult { PASS FAIL NEEDS_REPAIR }

model Inspection {
  id              String           @id @default(uuid())
  transformerId   String           @map("transformer_id")
  transformer     Transformer      @relation(fields: [transformerId], references: [id])
  inspectorId     String           @map("inspector_id")
  inspector       User             @relation("InspectorRel", fields: [inspectorId], references: [id])
  inspectionDate  DateTime         @map("inspection_date")
  checklist       Json?
  findings        String?
  result          InspectionResult @default(PASS)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([transformerId])
  @@map("inspections")
}

// ============================================
// HODISALAR
// ============================================

enum Severity { LOW MEDIUM HIGH CRITICAL }

model Incident {
  id            String    @id @default(uuid())
  transformerId String    @map("transformer_id")
  transformer   Transformer @relation(fields: [transformerId], references: [id])
  incidentType  String    @map("incident_type")
  description   String?
  occurredAt    DateTime  @map("occurred_at")
  severity      Severity  @default(LOW)
  reportedById  String?   @map("reported_by_id")
  reportedBy    User?     @relation("ReportedBy", fields: [reportedById], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([transformerId])
  @@map("incidents")
}

// ============================================
// ISH BUYURTMALARI
// ============================================

enum WorkOrderStatus { OPEN IN_PROGRESS CLOSED }
enum WorkOrderPriority { LOW MEDIUM HIGH URGENT }

model WorkOrder {
  id              String            @id @default(uuid())
  transformerId   String            @map("transformer_id")
  transformer     Transformer       @relation(fields: [transformerId], references: [id])
  title           String
  description     String?
  assignedToId    String?           @map("assigned_to_id")
  assignedTo      User?             @relation("AssignedTo", fields: [assignedToId], references: [id])
  dueDate         DateTime?         @map("due_date")
  status          WorkOrderStatus   @default(OPEN)
  priority        WorkOrderPriority @default(MEDIUM)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([transformerId])
  @@index([status])
  @@map("work_orders")
}


// ============================================
// NARYAD-IJOZAT (Ish ruxsatnomasi)
// ============================================

enum WorkPermitStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model WorkPermit {
  id                  String            @id @default(uuid())
  number              Int               @default(autoincrement())
  department          String?
  workSupervisor      String?           @map("work_supervisor")
  workPerformer       String?           @map("work_performer")
  watcherName         String?           @map("watcher_name")
  brigadeMembers      Json?             @map("brigade_members")
  transformerId       String?           @map("transformer_id")
  transformer         Transformer?      @relation(fields: [transformerId], references: [id])
  taskDescription     String?           @map("task_description")
  workStartDate       DateTime?         @map("work_start_date")
  workStartTime       String?           @map("work_start_time")
  workEndDate         DateTime?         @map("work_end_date")
  workEndTime         String?           @map("work_end_time")
  safetyMeasures      Json?             @map("safety_measures")
  specialInstructions String?           @map("special_instructions")
  issuedByName        String?           @map("issued_by_name")
  issuedByDate        DateTime?         @map("issued_by_date")
  permittedByName     String?           @map("permitted_by_name")
  permittedByDate     DateTime?         @map("permitted_by_date")
  dailyLogs           Json?             @map("daily_logs")
  brigadeChanges      Json?             @map("brigade_changes")
  status              WorkPermitStatus  @default(OPEN)
  createdById         String?           @map("created_by_id")
  createdBy           User?             @relation("WorkPermitCreatedBy", fields: [createdById], references: [id])
  regionId            String?           @map("region_id")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@map("work_permits")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
